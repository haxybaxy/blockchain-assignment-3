# Copy to .env and adjust for your local Ganache instance.

# RPC endpoint — default Ganache from docker-compose.yml
RPC_URL=http://127.0.0.1:8545

# Flask session secret (any random string for local dev)
FLASK_SECRET=change-me-in-dev

# Ganache's deterministic mnemonic. When the docker-compose or CLI is started
# with --wallet.deterministic=true this mnemonic is used by default.
GANACHE_MNEMONIC=myth like bonus scare over problem client lizard pioneer submit female collect
